;「PRINTCの文字幅」設定は26以上推奨

@EVENTFIRST
BEGIN SHOP


@EVENTSHOP

$Y_LOOP

@SHOW_SHOP
#DIM CLOTHE_ELE, 1
#DIM CLOTHE, 2
;変数list　PRINTCを管理する変数(小文字変数はこの関数内で自己完結する要素を示す(暫定的な定義))
#DIM list, 1
#DIM L_LOCAL, 1

;主要業務		オレンジ
;副次的業務		薄いオレンジ
;副次的業務		緑
;余暇			黄色
;その他			白色(デフォルト)



SETCOLOR 224,128,0
PRINTSINGLEFORM ------------------------------ 主要業務 %DRAWLINESTR%

PRINTLC [100] - 仕事
PRINTLC [101] - 出張
PRINTL 
RESETCOLOR

SETCOLOR 248,196,128
PRINTSINGLEFORM ------------------------------ 副次的行事 %DRAWLINESTR%

CALL ENT_PRINTC, 1
PRINTLC [115] - 旅行
CALL ENT_PRINTC
PRINTLC [117] - 休憩
CALL ENT_PRINTC
PRINTLC [119] - 買い物
CALL ENT_PRINTC
PRINTLC [120] - 練習
CALL ENT_PRINTC
PRINTLC [121] - スポーツ観戦
CALL ENT_PRINTC
PRINTLC [123] - 飲み会
CALL ENT_PRINTC
PRINTLC [124] - ゲームセンター
CALL ENT_PRINTC

RESETCOLOR
SETCOLOR 64,224,164
PRINTSINGLEFORM ------------------------------ 余暇 %DRAWLINESTR%
VARSET list, 0

CALL ENT_PRINTC, 1
PRINTLC [102] - 服を買う
CALL ENT_PRINTC
PRINTLC [103] - 能力表示
CALL ENT_PRINTC
PRINTLC [108] - アイテムを使う
CALL ENT_PRINTC
PRINTLC [110] - 資格表示
CALL ENT_PRINTC
PRINTLC [215] - 警備
PRINTL 


SETCOLOR 255,255,255
PRINTSINGLEFORM ------------------------------ その他 %DRAWLINESTR%
RESETCOLOR

CALL ENT_PRINTC, 1
PRINTLC [200] - SAVE
CALL ENT_PRINTC
PRINTLC [300] - LOAD
CALL ENT_PRINTC
PRINTLC [400] - 記録室
CALL ENT_PRINTC
PRINTLC [500] - CONFIG

@USERSHOP

IF RESULT >= 1
	PRINTFORMW {RESULT}が入力されました(関数処理表示用なので機能未実装)。
ENDIF

;-------------------------------------------------------------
;@ENT_PRINTC
;PRINTCを管理する変数
;PRINTCを使う場合、これを挿入すれば管理できる
;要求する変数：list
;ARG　listの値をリセットする
;-------------------------------------------------------------
@ENT_PRINTC, ARG
#DIM list, 1

IF ARG
	list = 0
ELSE
	list += 1
	IF list == 3
		PRINTL 
		list = 0
	ENDIF
ENDIF

